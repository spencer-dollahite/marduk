{
  "title": "Marduk read button",
  "rules": [
    {
      "description": "Read button: Marduk (Ctrl+Option+Escape) while marduk_up is 1, macOS Speak Selection (Option+Escape) otherwise. Default 'from' is equal_sign — Razer Naga side button 12 — scoped to Razer devices (vendor_id 5426) so the real keyboard's =/+ key keeps typing; adjust vendor_id/product_id per Karabiner-EventViewer. First matching manipulator wins, which implements the fallback.",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "equal_sign",
            "modifiers": {
              "optional": [
                "any"
              ]
            }
          },
          "conditions": [
            {
              "type": "variable_if",
              "name": "marduk_up",
              "value": 1
            },
            {
              "type": "device_if",
              "identifiers": [
                {
                  "vendor_id": 5426
                }
              ]
            }
          ],
          "to": [
            {
              "key_code": "escape",
              "modifiers": [
                "left_control",
                "left_option"
              ]
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "equal_sign",
            "modifiers": {
              "optional": [
                "any"
              ]
            }
          },
          "to": [
            {
              "key_code": "escape",
              "modifiers": [
                "left_option"
              ]
            }
          ],
          "conditions": [
            {
              "type": "device_if",
              "identifiers": [
                {
                  "vendor_id": 5426
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}\n